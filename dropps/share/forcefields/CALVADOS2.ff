# CALVADOS2 forcefield for slab simulation

[ function-type ]
#  LJ              Couloumb
   Ashbaugh-Hatch  Debye-Huckel

[ residue-epsilon ]
# epsilon for Ashbaugh-Hatch LJ in kJ/mol
    0.83736

[ relative-permittivity ]
5321 233.76 -0.9297 0.001417 -0.0000008292

[ simulation-setting ]
# name         value  type_at_NVT       type_at_NPT
  shift-lj     True   forced            forced
  shift-coul   True   forced            forced
  cutoff-lj    2      recommended       recommended
  cutoff-coul  4      recommended       recommended

